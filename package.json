{
  "name": "vue-fa",
  "version": "4.0.2",
  "description": "Tiny FontAwesome component for Vue.js",
  "keywords": [
    "fontawesome",
    "font-awesome",
    "vue",
    "vue.js",
    "component",
    "icon",
    "svg",
    "duotone"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cweili/vue-fa.git"
  },
  "author": "Cweili",
  "license": "MIT",
  "type": "module",
  "homepage": "https://cweili.github.io/vue-fa/",
  "bugs": {
    "url": "https://github.com/Cweili/vue-fa/issues"
  },
  "main": "dist/vue-fa.cjs.js",
  "module": "dist/vue-fa.esm.js",
  "unpkg": "dist/vue-fa.js",
  "jsdelivr": "dist/vue-fa.js",
  "source": "src/index.ts",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/vue-fa.esm.js",
      "require": "./dist/vue-fa.cjs.js",
      "default": "./dist/vue-fa.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:docs": "vite build --config docs/vite.config.ts",
    "dev": "vite --config docs/vite.config.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest --coverage",
    "lint": "eslint --fix \"{src,test,docs,docs/v2}/*.{js,ts,vue}\"",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@cweili/fa-test-util": "^1.0.0",
    "@fortawesome/fontawesome-common-types": "6.5.2",
    "@fortawesome/free-solid-svg-icons": "6.4.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/language-core": "^3.1.8",
    "@vue/server-renderer": "3.5",
    "autoprefixer": "10.5",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^16.5.0",
    "postcss": "8.5",
    "pretty": "^2.0.0",
    "typescript": "5.8",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "vue": "3.5",
    "vue-eslint-parser": "^9.4.3"
  },
  "peerDependencies": {
    "@fortawesome/fontawesome-common-types": "*",
    "vue": "^3.0.0"
  }
}
